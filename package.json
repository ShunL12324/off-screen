{
  "name": "off-screen",
  "version": "0.1.1",
  "description": "Stealth always-on-top transparent browser",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "lint": "eslint .",
    "icon": "bash scripts/build-icon.sh",
    "dist": "npm run icon && electron-builder"
  },
  "build": {
    "appId": "com.offscreen.app",
    "productName": "off-screen",
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns",
      "identity": null
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ShunL12324",
        "repo": "off-screen",
        "releaseType": "release"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.39.4",
    "globals": "^17.5.0"
  }
}
